{
  "id": "claude-code-wiremock",
  "version": "1.0.20260318221246",
  "name": "Claude Code Sandbox with WireMock",
  "description": "Sandboxed devcontainer for running Claude Code with firewall isolation, pre-configured for JVM/Kotlin projects with WireMock MCP server, Arazzo runner and WireMock skills plugin",
  "documentationUrl": "https://github.com/wiremock-inc/devcontainer-templates",
  "licenseUrl": "https://github.com/wiremock-inc/devcontainer-templates/blob/main/LICENSE",
  "platforms": [
    "Any"
  ],
  "options": {
    "javaVersion": {
      "type": "string",
      "description": "Java version (Eclipse Temurin JDK)",
      "proposals": [
        "17",
        "21",
        "25"
      ],
      "default": "17"
    },
    "timezone": {
      "type": "string",
      "description": "Container timezone",
      "proposals": [
        "Europe/London",
        "America/New_York",
        "America/Los_Angeles",
        "UTC"
      ],
      "default": "Europe/London"
    }
  }
}
